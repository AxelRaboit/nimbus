{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'admin.title'|trans }} - Nimbus{% endblock %}

{% block page_header_slot %}
    {% set tabLabels = {
        stats: 'Vue d\'ensemble',
        users: 'Utilisateurs',
        invitations: 'Invitations',
        parameters: 'Paramètres',
        transfers: 'Transferts',
        access_requests: 'Demandes d\'accès',
    } %}
    {{ include('components/page_header.html.twig', {
        crumbs: [
            {label: 'Administration', href: path('dev_dashboard')},
            {label: tabLabels[tab] ?? tab},
        ],
    }) }}
{% endblock %}

{% block body %}
<div {{ vue_component('DevApp', {
    tab: tab,
    stats: tab == 'stats' ? stats : {},
    transfers: tab == 'transfers' ? transfers : {},
    users: tab == 'users' ? users : {},
    parameters: tab == 'parameters' ? parameters : {},
    accessRequests: tab == 'access_requests' ? accessRequests : {},
    search: search ?? '',
    status: status ?? '',
    statsPath: path('dev_dashboard'),
    transfersPath: path('dev_transfers'),
    usersPath: path('dev_users'),
    invitationsPath: path('dev_invitations'),
    invitationSendPath: path('dev_invitation_send'),
    parametersPath: path('dev_parameters'),
    parameterUpdatePath: path('dev_parameter_update', {key: '__key__'}),
    userCreatePath: path('dev_user_create'),
    userUpdatePath: path('dev_user_update', {id: '__id__'}),
    userImpersonatePath: path('dev_user_impersonate', {id: '__id__'}),
    userDeletePath: path('dev_user_delete', {id: '__id__'}),
    userToggleRolePath: path('dev_user_toggle_role', {id: '__id__'}),
    userCustomFileSizePath: path('dev_user_custom_file_size', {id: '__id__'}),
    accessRequestsPath: path('dev_access_requests'),
    accessRequestApprovePath: path('dev_access_request_approve', {id: '__id__'}),
    accessRequestRejectPath: path('dev_access_request_reject', {id: '__id__'}),
    accessRequestPurgeApprovedPath: path('dev_access_request_purge_approved'),
    csrfToken: csrf_token('dev'),
}) }}></div>
{% endblock %}
