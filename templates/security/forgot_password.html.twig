{% extends 'base_guest.html.twig' %}

{% block title %}{{ 'auth.forgot_password.title'|trans }} - Nimbus{% endblock %}

{% block content %}
    {% if status %}
        <div class="mb-4 text-sm font-medium text-green-600">
            {{ status }}
        </div>
    {% endif %}

    {% if not status %}
        <div class="mb-4 text-sm text-secondary">
            {{ 'auth.forgot_password.instructions'|trans }}
        </div>

        <form method="POST" action="{{ path('app_forgot_password') }}">
            <div>
                {{ include('components/form_input.html.twig', {
                    id: 'email',
                    type: 'email',
                    name: 'email',
                    label: 'auth.login.email'|trans,
                    placeholder: 'auth.login.email_placeholder'|trans,
                    required: true,
                    autofocus: true,
                    autocomplete: 'email',
                }, false) }}
            </div>

            <div class="mt-4">
                {{ include('components/form_submit_button.html.twig', {
                    text: 'auth.forgot_password.submit'|trans,
                }, false) }}
            </div>
        </form>
    {% endif %}

    {{ include('components/divider_or.html.twig') }}

    <div class="mt-4 text-center">
        <a href="{{ path('app_login') }}" class="text-sm text-gray-600 hover:text-gray-900 underline transition-colors">
            {{ 'auth.forgot_password.back_login'|trans }}
        </a>
    </div>
{% endblock %}
