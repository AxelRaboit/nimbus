{% extends 'email/layout/base.html.twig' %}

{% block title %}{{ 'mail.transfer_expired.heading'|trans }} — Nimbus{% endblock %}

{% block content %}
<h1>{{ 'mail.transfer_expired.heading'|trans }}</h1>

<p>
    {{ 'mail.transfer_expired.intro'|trans({'%reference%': transfer.reference}) }}
</p>

{% set downloaded = transfer.recipients|filter(r => r.hasDownloaded)|length %}
{% set total = transfer.recipients|length %}
<p>{{ downloaded }}/{{ total }}</p>

<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="reference-cell">
            {{ transfer.reference }}
        </td>
    </tr>
</table>

<p class="warning">{{ 'mail.transfer_expired.footer'|trans }}</p>
{% endblock %}
