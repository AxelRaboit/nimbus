{% extends 'email/layout/base.html.twig' %}

{% block title %}{{ 'mail.transfer_reminder.heading'|trans }} — Nimbus{% endblock %}

{% block content %}
<h1>{{ 'mail.transfer_reminder.heading'|trans }}</h1>

<p>
    {{ 'mail.transfer_reminder.intro'|trans({'%senderName%': transfer.senderName ?? transfer.senderEmail ?? 'Nimbus', '%count%': transfer.files|length}) }}
</p>

{{ include('email/partials/file_list.html.twig') }}

{{ include('email/partials/action_button.html.twig', {
    url: downloadUrl,
    label: 'mail.transfer_reminder.download_button'|trans,
}) }}

<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="reference-cell">
            {{ 'mail.transfer_reminder.expires'|trans({'%date%': transfer.expiresAt|date('d/m/Y')}) }}
        </td>
    </tr>
</table>

<p class="warning">{{ 'mail.transfer_reminder.footer'|trans }}</p>
{% endblock %}
