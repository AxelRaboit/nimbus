{% extends 'email/layout/base.html.twig' %}

{% block title %}Vous avez reçu des fichiers — Nimbus{% endblock %}

{% block content %}
<h1>Vous avez reçu des fichiers</h1>

<p>
    <strong>{{ transfer.senderName ?? transfer.senderEmail ?? 'Quelqu\'un' }}</strong>
    vous a envoyé {{ transfer.files|length }} fichier{{ transfer.files|length > 1 ? 's' : '' }} via Nimbus.
</p>

{% if transfer.message %}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel">
            <div class="panel-content">{{ transfer.message }}</div>
        </td>
    </tr>
</table>
{% endif %}

<table class="file-list" role="presentation">
    {% for file in transfer.files %}
    <tr>
        <td>📄 {{ file.originalName }}</td>
        <td align="right" style="color:#9ca3af;white-space:nowrap;">
            {% if file.fileSize < 1048576 %}
                {{ (file.fileSize / 1024)|number_format(1) }} Ko
            {% else %}
                {{ (file.fileSize / 1048576)|number_format(1) }} Mo
            {% endif %}
        </td>
    </tr>
    {% endfor %}
</table>

<table class="action" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td align="center">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 auto;">
                <tr>
                    <td style="background-color:#4f46e5;border-radius:8px;">
                        <a href="{{ downloadUrl }}" class="button button-primary">
                            Télécharger les fichiers
                        </a>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>

<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="reference-cell">
            Référence : <strong>{{ transfer.reference }}</strong> — Expire le {{ transfer.expiresAt|date('d/m/Y') }}
        </td>
    </tr>
</table>

<p class="fallback">
    Si le bouton ne fonctionne pas, copiez ce lien dans votre navigateur :<br>
    <a href="{{ downloadUrl }}">{{ downloadUrl }}</a>
</p>

<p class="warning">Ce lien est personnel et vous est destiné. Ne le partagez pas.</p>
{% endblock %}
