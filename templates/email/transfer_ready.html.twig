{% extends 'email/layout/base.html.twig' %}

{% block title %}{{ 'mail.transfer_ready.heading'|trans }} — Nimbus{% endblock %}

{% block content %}
<h1>{{ 'mail.transfer_ready.heading'|trans }}</h1>

<p>
    {{ 'mail.transfer_ready.intro'|trans({'%senderName%': transfer.senderName ?? transfer.senderEmail ?? 'Nimbus', '%count%': transfer.files|length}) }}
</p>

{% if transfer.message %}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel">
            <div class="panel-content">{{ transfer.message }}</div>
        </td>
    </tr>
</table>
{% endif %}

{{ include('email/partials/file_list.html.twig') }}

{% if plainPassword %}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="panel">
            <div class="panel-content">
                {{ 'mail.transfer_ready.password_label'|trans }} : <strong>{{ plainPassword }}</strong>
            </div>
        </td>
    </tr>
</table>
{% endif %}

{{ include('email/partials/action_button.html.twig', {
    url: downloadUrl,
    label: 'mail.transfer_ready.download_button'|trans,
}) }}

<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="reference-cell">
            {{ 'mail.transfer_ready.expires'|trans({'%date%': transfer.expiresAt|date('d/m/Y')}) }}
        </td>
    </tr>
</table>

<p class="warning">{{ 'mail.transfer_ready.footer'|trans }}</p>
{% endblock %}
