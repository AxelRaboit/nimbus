{% apply inline_css(source('@styles/email.css')) %}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Nimbus{% endblock %}</title>
</head>
<body>

<table class="wrapper" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
<tr>
<td align="center">

    <table class="content" role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">

        {# Header #}
        <tr>
            <td class="header">
                <a href="https://nimbus.app" style="display: inline-block; text-decoration: none;">
                    <table cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin: 0 auto;">
                        <tr>
                            <td align="center" style="padding-bottom: 8px;">
                                <!--[if mso]>
                                <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" style="height:48px;width:48px;" arcsize="22%" fillcolor="#4f46e5" stroke="f">
                                    <v:textbox style="mso-fit-shape-to-text:false;" inset="0,0,0,0">
                                        <center style="color:#ffffff;font-family:'Segoe UI',sans-serif;font-size:26px;font-weight:700;">N</center>
                                    </v:textbox>
                                </v:roundrect>
                                <![endif]-->
                                <!--[if !mso]><!-->
                                <div style="width:48px;height:48px;background:linear-gradient(135deg,#6366f1,#4f46e5);background-color:#4f46e5;border-radius:11px;margin:0 auto;display:table-cell;text-align:center;vertical-align:middle;">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="-2 -2 28 28" width="32" height="32" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:block;margin:auto;">
                                        <path d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
                                    </svg>
                                </div>
                                <!--<![endif]-->
                            </td>
                        </tr>
                        <tr>
                            <td align="center" style="font-family:'Figtree','Segoe UI',sans-serif;font-size:19px;font-weight:700;color:#4f46e5;">
                                Nimbus
                            </td>
                        </tr>
                    </table>
                </a>
            </td>
        </tr>

        {# Body #}
        <tr>
            <td class="body">
                <table class="inner-body" role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                    <tr>
                        <td class="content-cell">
                            {% block content %}{% endblock %}
                        </td>
                    </tr>
                </table>
            </td>
        </tr>

        {# Footer #}
        <tr>
            <td>
                <table class="footer" role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                    <tr>
                        <td align="center" style="padding: 16px;">
                            <p>© {{ 'now'|date('Y') }} Nimbus. Tous droits réservés.</p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>

    </table>
</td>
</tr>
</table>

</body>
</html>
{% endapply %}
