{% extends 'email/layout/base.html.twig' %}

{% block title %}{{ 'mail.transfer_downloaded.heading'|trans }} — Nimbus{% endblock %}

{% block content %}
<h1>{{ 'mail.transfer_downloaded.heading'|trans }}</h1>

<p>
    {{ 'mail.transfer_downloaded.intro'|trans({'%recipientEmail%': recipient.email, '%reference%': transfer.reference}) }}
</p>

<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="reference-cell">
            {{ transfer.reference }}
        </td>
    </tr>
</table>

<p class="warning">
    {{ 'mail.transfer_downloaded.warning'|trans }}
</p>
{% endblock %}
