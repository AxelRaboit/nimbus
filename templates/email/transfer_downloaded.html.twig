{% extends 'email/layout/base.html.twig' %}

{% block title %}Vos fichiers ont été téléchargés — Nimbus{% endblock %}

{% block content %}
<h1>Vos fichiers ont été téléchargés</h1>

<p>
    <strong>{{ recipient.email }}</strong> a téléchargé vos fichiers du transfert
    <strong>{{ transfer.reference }}</strong>.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
    <tr>
        <td class="reference-cell">
            Référence : <strong>{{ transfer.reference }}</strong>
        </td>
    </tr>
</table>

<p class="warning">
    Si vous n'attendiez pas ce téléchargement, vous pouvez supprimer votre transfert depuis votre lien de gestion.
</p>
{% endblock %}
