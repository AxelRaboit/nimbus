<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Nimbus{% endblock %}</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg">
        <link rel="preconnect" href="https://fonts.bunny.net">
        <link rel="stylesheet" href="https://fonts.bunny.net/css?family=figtree:400,500,600,700&display=swap">
        {{ include('components/theme_script.html.twig', {colorScheme: true, sidebar: true}) }}
        {% block stylesheets %}
            {{ vite_entry_link_tags('app') }}
            {{ vite_entry_link_tags('sidebar') }}
            {{ vite_entry_link_tags('flash') }}
        {% endblock %}
        <script>window.__flash__ = {{ app.flashes|json_encode|raw }};</script>
        {% block javascripts %}
            {{ vite_entry_script_tags('app') }}
            {{ vite_entry_script_tags('sidebar') }}
            {{ vite_entry_script_tags('flash') }}
        {% endblock %}
    </head>
    <body class="transition-colors duration-200">
        <div class="min-h-screen bg-bg">

            <div id="app-sidebar"
                 data-user-name="{{ app.user ? app.user.name : '' }}"
                 data-user-email="{{ app.user ? app.user.email : '' }}"
                 data-app-version="{{ appVersion is defined ? appVersion : '' }}"
                 data-active-route="{{ app.request.attributes.get('_route') }}"
                 data-logout-csrf="{{ app.user ? csrf_token('logout') : '' }}"
                 data-home-path="{{ path('home') }}"
                 data-profile-path="{{ app.user ? path('profile') : '' }}"
                 data-logout-path="{{ app.user ? path('app_logout') : '' }}"
                 data-login-path="{{ path('app_login') }}"
                 data-is-guest="{{ app.user ? 'false' : 'true' }}"
                 data-is-dev="{{ app.user and is_granted('ROLE_DEV') ? 'true' : 'false' }}"
                 data-dev-path="{{ path('dev_dashboard') }}"
                 data-dashboard-path="{{ app.user ? path('transfers') : '' }}"
                 data-user-plan="{{ app.user ? app.user.plan.value : 'free' }}"
                 data-plan-path="{{ path('plan') }}"
                 data-locale="{{ app.request.locale }}"
            ></div>

            <div id="main-content" class="flex-1 flex flex-col min-h-screen transition-all duration-200 pt-14 lg:pt-0">

                {% block page_header_slot %}{% endblock %}

                {{ include('components/trial_banner.html.twig') }}

                <main class="flex-1 px-4 sm:px-6 lg:px-8 py-8">
                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>
    </body>
</html>
