{% extends 'base_guest.html.twig' %}

{% block title %}
    {% if success %}Accès autorisé{% elseif reason == 'expired' %}Lien expiré{% else %}Lien invalide{% endif %} - Nimbus
{% endblock %}

{% block content %}
<div class="flex-1 flex items-center justify-center p-4">
    <div class="w-full max-w-sm">
        <div class="rounded-xl border border-base bg-surface shadow-lg shadow-indigo-500/10 p-6 sm:p-8 text-center">

            {% if success %}
                <div class="flex justify-center mb-4">
                    <div class="w-12 h-12 rounded-full bg-emerald-500/10 flex items-center justify-center">
                        <svg class="w-6 h-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                </div>
                <h2 class="text-lg font-bold text-primary mb-2">Accès autorisé</h2>
                <p class="text-sm text-secondary">
                    Un e-mail a été envoyé à <strong class="text-primary">{{ requesterEmail }}</strong> avec un lien pour accéder à Nimbus.
                </p>
            {% elseif reason == 'expired' %}
                <div class="flex justify-center mb-4">
                    <div class="w-12 h-12 rounded-full bg-amber-500/10 flex items-center justify-center">
                        <svg class="w-6 h-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                </div>
                <h2 class="text-lg font-bold text-primary mb-2">Lien expiré</h2>
                <p class="text-sm text-secondary">Ce lien n'est plus valide. Le demandeur peut soumettre une nouvelle demande.</p>
            {% else %}
                <div class="flex justify-center mb-4">
                    <div class="w-12 h-12 rounded-full bg-red-500/10 flex items-center justify-center">
                        <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </div>
                </div>
                <h2 class="text-lg font-bold text-primary mb-2">Lien invalide</h2>
                <p class="text-sm text-secondary">Ce lien est invalide ou a déjà été utilisé.</p>
            {% endif %}

        </div>
    </div>
</div>
{% endblock %}
