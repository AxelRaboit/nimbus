{% if app.user and app.user.trialEndsAt and app.user.trialEndsAt > date() %}
    {% set daysLeft = ((app.user.trialEndsAt.timestamp - date().timestamp) / 86400)|round(0, 'ceil') %}
    {% if daysLeft > 0 %}
        <div class="bg-indigo-600/15 border-b border-indigo-500/40 px-4 py-2 flex items-center justify-center gap-3 text-xs text-indigo-400">
            <span>{{ 'plan.trial_banner'|trans({'%days%': daysLeft}) }}</span>
            <a href="{{ path('plan') }}" class="underline hover:text-indigo-200 transition-colors font-medium">
                {{ 'plan.trial_banner_cta'|trans }}
            </a>
        </div>
    {% endif %}
{% endif %}
