{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'transfer.create.title'|trans }} - Nimbus{% endblock %}

{% block page_header_slot %}
    {{ include('components/page_header.html.twig', {title: 'transfer.create.title'|trans}) }}
{% endblock %}

{% block body %}
    <div {{ vue_component('HomeApp', {
        userEmail: app.user ? app.user.email : '',
        isGuest: app.user ? false : true,
        maxSizeMb: maxSizeMb,
        proMaxSizeMb: proMaxSizeMb,
        maxFiles: maxFiles,
        maxRecipients: maxRecipients,
        maxExpiryDays: maxExpiryDays,
        tusCleanupMaxAgeHours: tusCleanupMaxAgeHours,
        expiryOptions: expiryOptions,
        extensionGroups: extensionGroups,
        accessPasswordEnabled: accessPasswordEnabled,
        accessGranted: accessGranted,
        isPro: isPro,
        planPath: path('plan'),
        loginPath: path('app_login'),
        registerPath: path('app_register'),
        registrationEnabled: registrationEnabled,
    }) }} class="flex-1"></div>
{% endblock %}
