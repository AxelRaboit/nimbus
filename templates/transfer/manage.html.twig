{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'transfer.manage.title'|trans }} - Nimbus{% endblock %}

{% block page_header_slot %}
    {{ include('components/page_header.html.twig', {title: 'transfer.manage.title'|trans}) }}
{% endblock %}

{% block body %}
    <div {{ vue_component('ManageApp', {
        ownerToken: transfer.ownerToken,
        reference: transfer.reference,
        status: transfer.status.value,
        expiresAt: transfer.expiresAt|date('c'),
        files: transfer.files|map(f => {name: f.originalName, size: f.fileSize}),
        recipients: transfer.recipients|map(r => {email: r.email, downloaded: r.hasDownloaded}),
        csrfToken: csrf_token,
        isPublic: transfer.isPublic,
        publicDownloadCount: transfer.publicDownloadCount,
        transferToken: transfer.token,
    }) }} class="flex-1"></div>
{% endblock %}
