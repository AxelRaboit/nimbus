{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'transfer.show.title'|trans }} - Nimbus{% endblock %}

{% block page_header_slot %}
    {{ include('components/page_header.html.twig', {title: 'transfer.show.title'|trans}) }}
{% endblock %}

{% block body %}
    <div {{ vue_component('TransferApp', {
        token: transfer.token,
        reference: transfer.reference,
        expiresAt: transfer.expiresAt|date('c'),
        senderName: transfer.senderName ?? '',
        files: transfer.files|map(f => {name: f.originalName, size: f.fileSize, mimeType: f.mimeType, filename: f.filename}),
    }) }}></div>
{% endblock %}
