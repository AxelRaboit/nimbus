{% extends 'base.html.twig' %}

{% block title %}Nimbus — Télécharger les fichiers{% endblock %}

{% block body %}
    <div id="app-transfer"
         data-token="{{ transfer.token }}"
         data-reference="{{ transfer.reference }}"
         data-expires-at="{{ transfer.expiresAt|date('c') }}"
         data-sender-name="{{ transfer.senderName ?? '' }}"
         data-files="{{ transfer.files|map(f => {name: f.originalName, size: f.fileSize, mimeType: f.mimeType})|json_encode }}">
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ vite_entry_script_tags('transfer') }}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ vite_entry_link_tags('transfer') }}
{% endblock %}
