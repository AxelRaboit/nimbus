{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'transfer.show.title'|trans }} - Nimbus{% endblock %}

{% block page_header_slot %}
    {{ include('components/page_header.html.twig', {title: 'transfer.show.title'|trans}) }}
{% endblock %}

{% block body %}
    <div id="app-transfer"
         data-token="{{ transfer.token }}"
         data-reference="{{ transfer.reference }}"
         data-expires-at="{{ transfer.expiresAt|date('c') }}"
         data-sender-name="{{ transfer.senderName ?? '' }}"
         data-files="{{ transfer.files|map(f => {name: f.originalName, size: f.fileSize, mimeType: f.mimeType, filename: f.filename})|json_encode }}"
         data-locale="{{ app.request.locale }}">
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ vite_entry_script_tags('transfer') }}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ vite_entry_link_tags('transfer') }}
{% endblock %}
