{% extends 'base_auth.html.twig' %}
{% block title %}{{ 'transfer.password.page_title'|trans }}{% endblock %}

{% block page_header_slot %}
    {{ include('components/page_header.html.twig', {title: 'transfer.password.title'|trans}) }}
{% endblock %}

{% block body %}
<div id="app-transfer-password"
     data-token="{{ transfer.token }}"
     data-unlock-path="{{ path('transfer_unlock', {token: transfer.token}) }}"
     data-csrf-token="{{ csrf_token('transfer_unlock_' ~ transfer.token) }}"
     data-locale="{{ app.request.locale }}"
</div>
{% endblock %}
{% block stylesheets %}{{ parent() }}{{ vite_entry_link_tags('transfer-password') }}{% endblock %}
{% block javascripts %}{{ parent() }}{{ vite_entry_script_tags('transfer-password') }}{% endblock %}
