{% extends 'base_auth.html.twig' %}
{% block title %}{{ 'transfer.password.page_title'|trans }}{% endblock %}

{% block page_header_slot %}
    {{ include('components/page_header.html.twig', {title: 'transfer.password.title'|trans}) }}
{% endblock %}

{% block body %}
<div {{ vue_component('TransferPasswordApp', {
    token: transfer.token,
    unlockPath: path('transfer_unlock', {token: transfer.token}),
    csrfToken: csrf_token('transfer_unlock_' ~ transfer.token),
}) }}></div>
{% endblock %}
