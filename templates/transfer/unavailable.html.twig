{% extends 'base_auth.html.twig' %}
{% block title %}{{ 'transfer.unavailable.page_title'|trans }}{% endblock %}

{% block page_header_slot %}
    {{ include('components/page_header.html.twig', {title: 'transfer.unavailable.title'|trans}) }}
{% endblock %}

{% block body %}
<div id="app-transfer-unavailable"
     data-status="{{ transfer.isExpired ? 'expired' : transfer.status.value }}"
     data-home-path="{{ path('home') }}"
     data-locale="{{ app.request.locale }}"
</div>
{% endblock %}
{% block stylesheets %}{{ parent() }}{{ vite_entry_link_tags('transfer-unavailable') }}{% endblock %}
{% block javascripts %}{{ parent() }}{{ vite_entry_script_tags('transfer-unavailable') }}{% endblock %}
