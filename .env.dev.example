APP_ENV=dev
APP_SECRET=generate_with__php_-r__echo_bin2hex(random_bytes(16))__
APP_DEBUG=true

# Database (PostgreSQL locally)
DATABASE_URL="postgresql://your_user:your_password@127.0.0.1:5432/nimbus_dev?serverVersion=16&charset=utf8"

# Messenger (doctrine transport)
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# Mail - Mailpit in Docker (http://localhost:8025)
MAILER_DSN=smtp://localhost:1025
MAILER_FROM_ADDRESS=noreply@nimbus.dev
MAILER_FROM_NAME=Nimbus
