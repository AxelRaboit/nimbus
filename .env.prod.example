APP_ENV=prod
APP_SECRET=change_me_with_strong_secret
APP_DEBUG=false

# Database (Production)
DATABASE_URL="postgresql://nimbus:your_password@127.0.0.1:5432/nimbus?serverVersion=16&charset=utf8"

# Messenger (doctrine transport — auto_setup=0 car la table est créée par les migrations)
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# Mail — Resend (https://resend.com)
MAILER_DSN=resend+api://YOUR_RESEND_API_KEY@default
MAILER_FROM_ADDRESS=noreply@yourdomain.com

# Uploads — chemin absolu vers le dossier de stockage (doit être writable par le process PHP)
# Par défaut : %kernel.project_dir%/var/uploads/transfers (défini dans services.yaml)
# Surcharger ici si le stockage est monté ailleurs en prod :
# TRANSFER_STORAGE_PATH=/var/nimbus/uploads/transfers
